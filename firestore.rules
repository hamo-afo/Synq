rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own profile data
    match /users/{userId} {
      // Allow users to read their profile and allow authenticated users to read basic data
      allow read: if request.auth.uid == userId || request.auth.uid != null;
      // Allow users to write their own document, and allow admins to update any user document
      allow write: if request.auth.uid == userId || (
        request.auth.uid != null &&
        // check if the caller is an admin by reading their users/{uid}.isAdmin flag
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
      allow create: if request.auth.uid != null;
    }

    // Trends - anyone authenticated can read. Only admins can write.
    match /trends/{docId} {
      allow read: if request.auth.uid != null;
      // Admins are identified by the users/{uid}.isAdmin flag in Firestore
      allow write: if request.auth.uid != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Posts - authenticated users can read all, write their own
    match /posts/{docId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid != null && request.resource.data.userId == request.auth.uid;
      
      // Allow any authenticated user to add comments to any post
      match /comments/{commentId} {
        allow read: if request.auth.uid != null;
        allow create: if request.auth.uid != null;
        allow write: if request.auth.uid == resource.data.userId;
        allow delete: if request.auth.uid == resource.data.userId;
      }
    }

    // Reports - authenticated users can read, write their own
    match /reports/{docId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid != null && request.resource.data.userId == request.auth.uid;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
